# Copy this file to .env and fill in real values for your machine/deployment.
# .env is gitignored and dockerignored — never commit real secrets.
#
#   cp .env.example .env

# Port the Flask server listens on (see app.run() in backend/main.py).
PORT=6767

# Bootstrap secret used to grant the very first admin account (see
# /api/admin/promote in backend/main.py). CHANGE THIS before deploying
# anywhere real — anyone who knows it can self-promote to admin.
ADMIN_SECRET=admin@12345

# Full path to the `sage` binary, only needed if it isn't already on the
# PATH the Flask process sees (e.g. a conda env or tarball install under
# $HOME). Leave unset to just use whatever `sage` resolves to on PATH.
# SAGE_BINARY=/home/youruser/SageMath/sage

# How the code judge runs Sage submissions:
#   local  (default) — subprocess to a real local `sage` install (see
#                       SAGE_BINARY above)
#   remote            — use the public SageMathCell service instead, so no
#                       local Sage install is needed (no SLA — expect
#                       occasional slowness/unavailability)
SAGE_MODE=local
